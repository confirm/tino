{
  "scripts": {
    "build": "npm run build:prism && npm run build:yjs",
    "build:prism": "cat node_modules/prismjs/prism.js confirm/typr/static/js/prism-typst.js | esbuild --minify --loader=js --log-level=warning > confirm/typr/static/js/vendor/prism.js",
    "build:yjs": "esbuild --bundle --minify --format=esm --log-level=warning --outfile=confirm/typr/static/js/vendor/yjs.js confirm/typr/static/js/yjs-entry.js"
  },
  "dependencies": {
    "prismjs": "^1.30.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
